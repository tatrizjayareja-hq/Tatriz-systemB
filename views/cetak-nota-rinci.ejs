<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Nota Rinci - <%= po.nama_po %></title>
    <style>
        @media print { 
            @page { 
                size: 105mm 148mm; /* Ukuran A6 Portrait */
                margin: 0; 
            } 
            body { 
                -webkit-print-color-adjust: exact; 
                print-color-adjust: exact;
            } 
            .no-print { display: none; }
        }

        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            margin: 0; 
            padding: 0;
            background-color: #fff;
            color: #333;
        }

        /* Container Utama dikunci ke A6 Portrait */
        .nota-box { 
            width: 105mm; 
            height: 148mm; 
            position: relative; 
            padding: 8mm; 
            box-sizing: border-box; 
            overflow: hidden; 
            display: flex;
            flex-direction: column;
            border: 1px solid #eee;
        }
        
        /* Header */
        .header-container { 
            display: flex; 
            align-items: center; 
            border-bottom: 2px solid #333; 
            padding-bottom: 8px; 
            margin-bottom: 8px; 
        }
        .logo-header { 
            width: 45px; 
            height: 45px; 
            object-fit: contain; 
            margin-right: 10px; 
        }
        .company-info { flex-grow: 1; }
        .company-info h2 { margin: 0; font-size: 12px; color: #2c3e50; text-transform: uppercase; }
        .company-info p { margin: 1px 0; font-size: 8px; line-height: 1.2; }

        .label-nota { text-align: right; }
        .label-nota h4 { margin: 0; color: #8e44ad; font-size: 10px; }
        .label-nota p { margin: 2px 0 0 0; font-size: 8px; }

        /* Watermark */
        .watermark { 
            position: absolute; 
            top: 50%; 
            left: 50%; 
            transform: translate(-50%, -50%) rotate(-30deg);
            opacity: 0.05; 
            width: 220px; 
            z-index: 0; 
            pointer-events: none;
        }

        /* Tabel Rincian */
        .content-area { position: relative; z-index: 1; flex-grow: 1; }
        table { width: 100%; border-collapse: collapse; margin-top: 5px; font-size: 9px; }
        th { background: #f8f9fa; border-bottom: 1px solid #333; padding: 5px; text-align: left; }
        td { border-bottom: 1px solid #eee; padding: 6px 4px; vertical-align: top; }
        
        /* Footer */
        .footer-nota { 
            margin-top: auto; 
            padding-top: 5px;
        }
        
        .total-box { 
            width: 100%;
            margin-bottom: 5px;
        }
        .total-row { 
            display: flex; 
            justify-content: space-between; 
            margin-bottom: 2px;
            font-size: 10px;
        }
        
        .ttd-section { 
            display: flex; 
            justify-content: space-between; 
            margin-top: 10px; 
            font-size: 9px; 
            text-align: center; 
        }
        .ttd-box { width: 45%; }
        .ttd-space { height: 30px; }
    </style>
</head>
<body>
    <div class="nota-box">
        <img src="/uploads/<%= config.logo_path %>" class="watermark">

        <div class="header-container">
            <img src="/uploads/<%= config.logo_path %>" class="logo-header">
            <div class="company-info">
                <h2><%= config.nama_perusahaan %></h2>
                <p><%= config.alamat.replace(/\n/g, ' ') %></p>
                <p><strong>WA: <%= config.no_hp %></strong></p>
            </div>
            <div class="label-nota">
                <h4>NOTA RINCIAN</h4>
                <p>Tgl: <%= new Date().toLocaleDateString('id-ID') %></p>
                <p>Cust: <strong><%= po.customer %></strong></p>
            </div>
        </div>

        <div class="content-area">
            <table>
                <thead>
                    <tr>
                        <th style="width: 40%;">Deskripsi Item</th>
                        <th style="text-align: center; width: 10%;">Qty</th>
                        <th style="text-align: right; width: 20%;">Harga</th>
                        <th style="text-align: right; width: 30%;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <% details.forEach(item => { %>
                        <tr>
                            <td>
                                <b><%= item.jenis_bordir %></b><br>
                                <span style="font-size: 8px; color: #666;"><%= item.nama_desain %></span>
                            </td>
                            <td style="text-align: center;"><%= item.jumlah %></td>
                            <td style="text-align: right;">
                                <%= item.harga_customer.toLocaleString('id-ID') %>
                            </td>
                            <td style="text-align: right;">
                                <%= (item.jumlah * item.harga_customer).toLocaleString('id-ID') %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="footer-nota">
            <div class="total-box">
                <div class="total-row">
                    <span>Total Tagihan:</span>
                    <span>Rp <%= po.total_harga_customer.toLocaleString('id-ID') %></span>
                </div>
                <div class="total-row" style="color: #27ae60;">
                    <span>Total Bayar:</span>
                    <span>Rp <%= (po.total_bayar || 0).toLocaleString('id-ID') %></span>
                </div>
                <hr style="border: 0; border-top: 1px solid #333; margin: 3px 0;">
                <div class="total-row" style="font-weight: bold; font-size: 12px;">
                    <span>SISA:</span>
                    <span>Rp <%= (po.total_harga_customer - (po.total_bayar || 0)).toLocaleString('id-ID') %></span>
                </div>
            </div>

            <div class="ttd-section">
                <div class="ttd-box">
                    Penerima,
                    <div class="ttd-space"></div>
                    ( ............................ )
                </div>
                <div class="ttd-box">
                    Hormat Kami,
                    <div class="ttd-space"></div>
                    ( ............................ )
                </div>
            </div>
        </div>
    </div>

    <script>
        window.onload = function() {
            // 1. Set Nama File PDF Otomatis
            const namaCust = "<%= po.customer %>";
            const namaPO = "<%= po.nama_po %>";
            const tgl = new Date().toLocaleDateString('id-ID').replace(/\//g, '-');
            
            document.title = "Nota_Rinci_" + namaCust.replace(/\s+/g, '_') + "_" + namaPO.replace(/\s+/g, '_') + "_" + tgl;
            
            // 2. Jalankan Print
            setTimeout(() => {
                window.print();
            }, 500);
        };
    </script>
</body>
</html>