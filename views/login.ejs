<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Tatriz SystemB</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --dark-green: #195e0b;
            --primary-green: #59cf77;
            --accent-green: #48b865;
            --text-gray: #636e72;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #195e0b 0%, #48b865 100%);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- CONTAINER UTAMA --- */
        .login-container {
            width: 450px; /* Ukuran ideal untuk form vertikal */
            max-width: 90%;
            margin: 20px auto;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column; /* ATAS - BAWAH */
        }

        /* --- BAGIAN ATAS: BRANDING --- */
        .card-header {
            background: white;
            padding: 40px 30px 20px;
            text-align: center;
        }

        .card-header img {
            width: 120px;
            height: auto;
            margin-bottom: 15px;
        }

        .card-header h1 {
            color: var(--dark-green);
            margin: 0;
            font-size: 26px;
            font-weight: 800;
        }

        .card-header .tagline {
            color: var(--text-gray);
            font-size: 14px;
            margin-top: 8px;
            line-height: 1.4;
        }

        /* --- BAGIAN BAWAH: FORM --- */
        .card-body {
            background-color: var(--dark-green);
            color: white;
            padding: 40px 35px;
        }

        .card-body h2 {
            margin: 0 0 5px 0;
            font-size: 22px;
            text-align: center;
        }

        .card-body p {
            font-size: 13px;
            opacity: 0.7;
            margin-bottom: 25px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 11px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.5);
        }

        .input-wrapper input {
            width: 100%;
            padding: 14px 15px 14px 45px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 10px;
            color: white;
            box-sizing: border-box;
            outline: none;
            transition: 0.3s;
            font-size: 16px; /* Mencegah auto-zoom di iPhone */
        }

        .input-wrapper input:focus {
            background: rgba(255,255,255,0.15);
            border-color: var(--primary-green);
            box-shadow: 0 0 0 4px rgba(89, 207, 119, 0.1);
        }

        .btn-login {
            width: 100%;
            padding: 15px;
            background: var(--primary-green);
            color: var(--dark-green);
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-login:hover {
            background: white;
            transform: translateY(-2px);
        }

        /* --- FOOTER / LINK --- */
        .card-footer {
            padding: 20px;
            text-align: center;
            background: #f9f9f9;
            font-size: 13px;
        }

        .card-footer a {
            color: var(--dark-green);
            text-decoration: none;
            font-weight: bold;
        }

        /* Info Sistem Baru */
        .setup-info {
            margin-top: 15px;
            padding: 10px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            font-size: 12px;
            color: #fab1a0;
            text-align: center;
        }

        /* Responsive Mobile */
        @media (max-width: 480px) {
            .login-container { width: 95%; }
            .card-header { padding: 30px 20px 15px; }
            .card-body { padding: 30px 20px; }
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card">
            <div class="card-header">
                <img src="/img/Tatriz SystemB.png" alt="Logo Tatriz SystemB">
                <h1>Tatriz SystemB</h1>
                <p class="tagline">Solusi digital cerdas untuk manajemen bordir profesional.</p>
            </div>

            <div class="card-body">
                <h2>Portal Masuk</h2>
                <p>Gunakan akun terdaftar Anda</p>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label>Username</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user"></i>
                            <input type="text" name="username" placeholder="Username" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <div class="input-wrapper">
                            <i class="fas fa-lock"></i>
                            <input type="password" name="password" placeholder="Password" required>
                        </div>
                    </div>
                    <button type="submit" class="btn-login">Masuk Sekarang</button>
                </form>

                <% if (isNew) { %>
                <div class="setup-info">
                    <i class="fas fa-info-circle"></i> Sistem baru. 
                    <a href="/setup-auth" style="color: white; text-decoration: underline;">Klik Setup Awal</a>
                </div>
                <% } %>
            </div>

            <div class="card-footer">
                Belum bergabung? <a href="/register">Daftar Perusahaan</a>
            </div>
        </div>
    </div>

</body>
</html>