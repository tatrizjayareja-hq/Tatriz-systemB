<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail PO - <%= po.nama_po %></title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f7f6; padding: 20px; }
        .card { background: white; padding: 25px; border-radius: 12px; max-width: 900px; margin: auto; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .header-info { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; border-bottom: 2px solid #eee; padding-bottom: 15px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background: #f8f9fa; }
        .status-box { padding: 15px; border-radius: 8px; background: #e8f5e9; margin-top: 20px; display: flex; justify-content: space-between; align-items: center; }
        select { padding: 8px; border-radius: 4px; border: 1px solid #ccc; }
        .btn-update { background: #59cf77; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer; }
    </style>
</head>
<body>

<div class="card">
    <a href="/po-data">← Kembali ke Daftar PO</a>
    <h2>Detail Pesanan: <%= po.nama_po %></h2>
    
    <div class="header-info">
        <div>
            <p><strong>Customer:</strong> <%= po.customer %></p>
            <p><strong>Tanggal:</strong> <%= po.tanggal %></p>
        </div>
        <div>
            <p><strong>Status Saat Ini:</strong> <span style="color: blue;"><%= po.status %></span></p>
            <p><strong>Total Tagihan:</strong> Rp <%= po.total_harga_customer.toLocaleString() %></p>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Jenis Bordir</th>
                <th>Nama Desain</th>
                <th>Jumlah</th>
                <th>Harga Cust</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            <% details.forEach(item => { %>
                <tr>
                    <td><%= item.jenis_bordir %></td>
                    <td><%= item.nama_desain %></td>
                    <td><%= item.jumlah %> pcs</td>
                    <td>Rp <%= item.harga_customer.toLocaleString() %></td>
                    <td>Rp <%= (item.jumlah * item.harga_customer).toLocaleString() %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <div class="status-box">
        <div>
            <strong>Ganti Status Produksi:</strong>
        </div>
        <form action="/update-status/<%= po.id %>" method="POST">
            <select name="status_baru">
                <option value="Design" <%= po.status === 'Design' ? 'selected' : '' %>>Design</option>
                <option value="Produksi" <%= po.status === 'Produksi' ? 'selected' : '' %>>Produksi</option>
                <option value="CMT" <%= po.status === 'CMT' ? 'selected' : '' %>>CMT</option>
                <option value="QC" <%= po.status === 'QC' ? 'selected' : '' %>>QC</option>
                <option value="Clear" <%= po.status === 'Clear' ? 'selected' : '' %>>Clear (Invoice)</option>
                <option value="DP/Cicil" <%= po.status === 'DP/Cicil' ? 'selected' : '' %>>DP/Cicil</option>
                <option value="Lunas" <%= po.status === 'Lunas' ? 'selected' : '' %>>Lunas</option>
            </select>
            <button type="submit" class="btn-update">Update Status</button>
        </form>
    </div>
</div>

</body>
</html>