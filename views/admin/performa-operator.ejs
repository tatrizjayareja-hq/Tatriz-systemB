<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-person-badge"></i> Analisis Performa Operator</h4>
        <form action="/performa-operator" method="GET" class="d-flex gap-2">
            <input type="month" name="bulan" value="<%= bulanIni %>" class="form-control form-control-sm" onchange="this.form.submit()">
        </form>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-4"><i class="bi bi-trophy"></i> Peringkat Produktivitas (Akumulasi Borongan Bulan Ini)</h6>
                    <div style="height: 300px;">
                        <canvas id="chartPerformaOps"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h6 class="mb-0 fw-bold">Matriks Produksi Harian</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle mb-0" style="font-size: 12px;">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 80px;">Tgl</th>
                        <% operators.forEach(op => { %>
                            <th><%= op.nama_lengkap %></th>
                        <% }) %>
                        <th class="bg-warning text-dark">Total Upah (Op)</th>
                        <th class="bg-primary">Total Omzet (Cust)</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let d = 1; d <= jumlahHari; d++) { 
                        let tglKey = bulanIni + "-" + String(d).padStart(2, '0');
                        let dataTgl = matriks[tglKey] || null;
                    %>
                    <tr>
                        <td class="text-center fw-bold"><%= String(d).padStart(2, '0') %>/<%= bulanIni.split('-')[1] %></td>
                        <% operators.forEach(op => { 
                            let upah = dataTgl ? (dataTgl[op.id] || 0) : 0;
                        %>
                            <td class="text-end <%= upah == 0 ? 'bg-light text-danger' : '' %>">
                                <%= upah > 0 ? 'Rp ' + upah.toLocaleString('id-ID') : '-' %>
                            </td>
                        <% }) %>
                        <td class="text-end fw-bold bg-warning bg-opacity-10">
                            Rp <%= dataTgl ? dataTgl.total_upah_op.toLocaleString('id-ID') : 0 %>
                        </td>
                        <td class="text-end fw-bold bg-primary bg-opacity-10 text-primary">
                            Rp <%= dataTgl ? dataTgl.total_omzet_cust.toLocaleString('id-ID') : 0 %>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Trik agar VS Code tidak error: Bungkus dalam kutip lalu di-parse
    // @ts-ignore
    const rawData = JSON.parse('<%- JSON.stringify(performaOps) %>');
    
    // Ubah data menjadi array dan urutkan berdasarkan upah tertinggi
    const sortedData = Object.values(rawData).sort((a, b) => {
        // @ts-ignore
        return b.totalUpah - a.totalUpah;
    });
    
    const labels = sortedData.map(item => item.nama);
    const datasetUpah = sortedData.map(item => item.totalUpah);

    const ctx = document.getElementById('chartPerformaOps');
    
    if (ctx) {
        // @ts-ignore
        new Chart(ctx.getContext('2d'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Total Produksi (Rp)',
                    data: datasetUpah,
                    backgroundColor: 'rgba(46, 204, 113, 0.7)',
                    borderColor: 'rgba(46, 204, 113, 1)',
                    borderWidth: 1,
                    borderRadius: 8,
                    barThickness: 25,
                }]
            },
            options: {
                indexAxis: 'y', // Grafik Horizontal
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            footer: (tooltipItems) => {
                                const index = tooltipItems[0].dataIndex;
                                const capai = sortedData[index].kaliCapaiTarget;
                                return `Target Tercapai: ${capai} kali`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        grid: { display: false },
                        ticks: {
                            callback: function(value) {
                                return 'Rp ' + value.toLocaleString('id-ID');
                            }
                        }
                    },
                    y: { grid: { display: false } }
                }
            }
        });
    }
</script>

<%- include('../partials/footer') %>