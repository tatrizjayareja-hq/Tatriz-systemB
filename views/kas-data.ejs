<%- include('partials/header') %>

<style>
    /* Menggunakan Class CSS untuk menghindari error linter pada inline style */
    .row-pemasukan { background-color: #f0fff4 !important; }
    .row-pengeluaran { background-color: #fff5f5 !important; }
    .text-pemasukan { color: #27ae60; font-weight: bold; }
    .text-pengeluaran { color: #d63031; font-weight: bold; }
    .sticky-filter { position: sticky; top: 0; z-index: 100; background: #f4f7f6; padding-bottom: 10px; }
</style>

<div class="container mt-4" style="max-width: 1000px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-cash-stack"></i> Riwayat Arus Kas</h4>
        <a href="/input-kas" class="btn btn-success fw-bold">
            <i class="bi bi-plus-circle"></i> TAMBAH TRANSAKSI
        </a>
    </div>

    <div class="card mb-3 shadow-sm sticky-filter">
        <div class="card-body py-2">
            <form action="/kas-data" method="GET" id="filterForm" class="row g-2 align-items-center">
                <div class="col-auto"><label class="small fw-bold">Pilih Periode:</label></div>
                <div class="col-auto">
                    <input type="month" name="bulan" value="<%= typeof bulanIni !== 'undefined' ? bulanIni : '' %>" 
                           class="form-control form-control-sm" onchange="this.form.submit()">
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Tgl</th>
                        <th>Kategori / Keterangan</th>
                        <th class="text-end">Jumlah</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof rincianKas !== 'undefined' && rincianKas.length > 0) { %>
                        <% rincianKas.forEach(item => { %>
                            <tr class="<%= item.jenis === 'PEMASUKAN' ? 'row-pemasukan' : 'row-pengeluaran' %>">
                                <td class="small"><%= item.tanggal.split('-').reverse().join('/') %></td>
                                <td>
                                    <strong class="text-uppercase" style="font-size: 12px;"><%= item.kategori %></strong><br>
                                    <span class="text-muted small">
                                        <%= item.keterangan %> 
                                        <%= item.nama_po ? '(PO: ' + item.nama_po + ')' : '' %>
                                    </span>
                                </td>
                                <td class="text-end <%= item.jenis === 'PEMASUKAN' ? 'text-pemasukan' : 'text-pengeluaran' %>">
                                    <%= item.jenis === 'PEMASUKAN' ? '+' : '-' %> Rp <%= item.jumlah.toLocaleString('id-ID') %>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-outline-primary" 
                                            onclick="persiapanEditKas('<%= item.id %>', '<%= item.tanggal %>', '<%= item.jenis %>', '<%= item.kategori %>', '<%= item.jumlah %>', '<%= item.keterangan %>', '<%= item.po_id %>')">
                                            ✏️ Edit
                                        </button>
                                        <a href="/hapus-kas/<%= item.id %>" class="btn btn-sm btn-outline-danger" 
                                           onclick="return confirm('Hapus data transaksi ini?')">🗑️</a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-info-circle"></i> Tidak ada transaksi pada periode ini.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-4 text-center">
        <a href="/dashboard" class="btn btn-sm btn-link text-decoration-none text-muted">← Kembali ke Dashboard Utama</a>
    </div>
</div>

<script>
function persiapanEditKas(id, tgl, jenis, kat, jml, ket, poId) {
    const dataEdit = { id, tgl, jenis, kat, jml, ket, poId };
    sessionStorage.setItem('editDataKas', JSON.stringify(dataEdit));
    window.location.href = '/input-kas';
}
</script>

<%- include('partials/footer') %>